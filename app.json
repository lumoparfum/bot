{
  "expo": {
    "name": "Stop82",
    "slug": "stop82",
    "scheme": "stop82",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "backgroundColor": "#1A2238",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.stop82.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.stop82.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#1A2238",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#1A2238"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Stop82'nin ilanına fotoğraf ekleyebilmesi için galerine erişmesi gerekiyor."
        }
      ],
      "expo-web-browser",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.83899072995-1rnjn8n6ohtt6c1cprlucd6ootad89qk"
        }
      ],
      "expo-apple-authentication",
      "expo-font",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Stop82'nin sana yakın ilanları gösterebilmesi için konumuna erişmesi gerekiyor."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#FF6B35"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "extraPods": [
              { "name": "AppCheckCore", "modular_headers": true },
              { "name": "GoogleUtilities", "modular_headers": true },
              { "name": "RecaptchaInterop", "modular_headers": true }
            ]
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "c0648885-e62f-42d4-aaae-4954e84fc8cc"
      }
    },
    "owner": "toraman",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/c0648885-e62f-42d4-aaae-4954e84fc8cc"
    }
  }
}
