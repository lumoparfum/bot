# Firebase project config (Project Settings > General > Your apps > Web app)
# Copy this file to .env and fill in your values. Expo automatically inlines
# any EXPO_PUBLIC_* variable into the app at build time.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Google Sign-In (Firebase Console > Authentication > Sign-in method > Google > Web SDK configuration)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# Google Sign-In on iOS (Firebase Console > Project Settings > Your apps > iOS app > GoogleService-Info.plist > CLIENT_ID)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
