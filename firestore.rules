rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if true;
      allow create, delete: if request.auth != null && request.auth.uid == userId;
      // Kendi profilini guncelleyebilirsin ama "guven sinyali" alanlarina
      // (puanlama, hesap yasi, yanit orani) dokunamazsin - bunlar sadece
      // baskalarinin degerlendirmesi ya da Cloud Functions tarafindan
      // (Admin SDK, bu kurallari zaten atlar) hesaplanir. Aksi halde
      // teknik bilgisi olan biri Firestore'a dogrudan yazip kendine sahte
      // 5 yildiz veya sahte "1 yildir uye" rozeti verebilirdi. ratingSum/
      // ratingCount istemciden HICBIR SEKILDE yazilamaz - reviews alt
      // koleksiyonuna dusen her yazimda functions/index.js'teki
      // onReviewWritten (Admin SDK) tarafindan yeniden hesaplanir.
      allow update: if request.auth != null
        && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
             'ratingSum', 'ratingCount', 'createdAt',
             'contactedCount', 'responseCount', 'responseTimeTotalMinutes'
           ]);

      match /favorites/{listingId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /reviews/{raterId} {
        allow read: if true;
        // Sadece bu kullanicidan onayli bir alisveris yapmis (buyers kaydi
        // olan) kisiler degerlendirme birakabilir - rastgele/sahte yorum onlemi.
        allow write: if request.auth != null && request.auth.uid == raterId && raterId != userId
          && exists(/databases/$(database)/documents/users/$(userId)/buyers/$(raterId));
      }

      // Satici bir ilani "satildi" olarak isaretlerken hangi aliciya sattigini
      // secerse buraya kalici bir kayit dusulur - sadece satici (userId)
      // olusturabilir, kimse degistiremez/silemez. Degerlendirme yetkisi
      // bu kayda bakar.
      match /buyers/{buyerId} {
        allow read: if request.auth != null && (request.auth.uid == userId || request.auth.uid == buyerId);
        allow create: if request.auth != null && request.auth.uid == userId;
        allow update, delete: if false;
      }

      // Bildirimler sadece Cloud Functions (Admin SDK) tarafindan olusturulur,
      // istemciden create yok - sadece sahibi okuyup okundu isaretleyebilir.
      match /notifications/{notificationId} {
        allow read, update: if request.auth != null && request.auth.uid == userId;
      }

      // Engelledigin kullanicilar - sadece sen gorup ekleyip kaldirabilirsin.
      // Sohbet/mesaj olusturma kurallari buraya bakarak engellenen kisinin
      // mesaj atmasini engeller.
      match /blockedUsers/{blockedId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create, delete: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /listings/{listingId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.sellerId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.sellerId == request.auth.uid;
      // Ilan sahibi her seyi guncelleyebilir - "favoriteCount" haric, o sadece
      // Cloud Functions tarafindan hesaplanir (aksi halde satici kendi
      // ilanina sahte "23 kisi favoriledi" sosyal kaniti yazabilirdi).
      // Baskalari sadece goruntulenme sayacini tam olarak birer birer
      // artirabilir (rastgele bir sayiya "set" edip sahte "50000 goruntulenme"
      // sosyal kaniti yaratamasinlar diye - client zaten sadece increment(1)
      // kullaniyor, bkz. src/services/firestore.ts).
      allow update: if request.auth != null && (
        (resource.data.sellerId == request.auth.uid
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['favoriteCount'])) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount'])
          && request.resource.data.viewCount == resource.data.viewCount + 1)
      );

      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null && request.auth.uid == request.resource.data.authorId;
        // Yorumu yazan kendi yorumunu silebilir; ilan sahibi ise sadece
        // "hidden" alanini true yapabilir (kanit kalsin diye tam silemez).
        // Uygulamada yorum "duzenleme" ozelligi yok (bkz. src/services/
        // comments.ts - tek update cagrisi seller'in hideComment'i), o yuzden
        // yazarin kendi yorumunu guncelleme hakki yok - aksi halde satici bir
        // yorumu gizledikten sonra yazar "hidden"i geri false yapabilir ya da
        // authorId'yi baskasina cevirip yorumu ona mal edebilirdi.
        allow delete: if request.auth != null && request.auth.uid == resource.data.authorId;
        allow update: if request.auth != null
          && get(/databases/$(database)/documents/listings/$(listingId)).data.sellerId == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['hidden']);
      }
    }

    // Sikayetler: sadece gonderen olusturabilir, kimse okuyup/guncelleyip/
    // silemez - tek erisim Firebase Console'dan (Admin SDK, proje sahibi).
    match /reports/{reportId} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.reporterId;
      allow read, update, delete: if false;
    }

    match /conversations/{conversationId} {
      // resource == null olan dal, henuz olusturulmamis bir sohbeti kontrol
      // etmek icin yapilan getDoc() cagrisina izin verir (getOrCreateConversation).
      allow read: if request.auth != null
        && (resource == null || request.auth.uid in resource.data.participantIds);
      allow update: if request.auth != null && request.auth.uid in resource.data.participantIds;
      // Karsi taraf beni engellemisse yeni bir sohbet baslatamam.
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participantIds
        && !exists(/databases/$(database)/documents/users/$(
             request.resource.data.buyerId == request.auth.uid
               ? request.resource.data.sellerId
               : request.resource.data.buyerId
           )/blockedUsers/$(request.auth.uid));

      match /messages/{messageId} {
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        // Karsi taraf beni engellemisse yeni mesaj gonderemem (eski mesajlar
        // okunabilir kalir, sadece yeni mesaj engellenir).
        allow create: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds
          && request.resource.data.senderId == request.auth.uid
          && !exists(/databases/$(database)/documents/users/$(
               get(/databases/$(database)/documents/conversations/$(conversationId)).data.buyerId == request.auth.uid
                 ? get(/databases/$(database)/documents/conversations/$(conversationId)).data.sellerId
                 : get(/databases/$(database)/documents/conversations/$(conversationId)).data.buyerId
             )/blockedUsers/$(request.auth.uid));
        // Bir teklife sadece teklifi alan taraf (gonderen degil) cevap
        // verebilir, ve sadece offerStatus alanini degistirebilir.
        allow update: if request.auth != null
          && request.auth.uid != resource.data.senderId
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['offerStatus']);
      }
    }

    // Destek talepleri: sadece gonderen olusturabilir ve kendi gonderdiklerini
    // (gunluk spam limitini istemci tarafinda sayabilmek icin) okuyabilir -
    // kimse guncelleyip/silemez, inceleme tek Firebase Console'dan.
    match /supportRequests/{requestId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.uid;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uid;
      allow update, delete: if false;
    }

    // Isletme hesabi basvurulari: sadece basvuran olusturabilir ve kendi
    // basvurusunu okuyup durumunu (inceleniyor/onayland/reddedildi) takip
    // edebilir. Durumu sadece Stop82 ekibi Firebase Console'dan (Admin SDK)
    // degistirebilir - istemciden update/delete yok.
    match /businessRequests/{requestId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.uid;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uid
        && request.resource.data.status == 'pending';
      allow update, delete: if false;
    }

    match /savedSearches/{searchId} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uid;
      allow read, delete: if request.auth != null && request.auth.uid == resource.data.uid;
    }

    // Tanitim sitesindeki "haber ver" bekleme listesi - ziyaretci giris
    // yapmamis olacagi icin kimliksiz create'e izin verilir (reports/
    // supportRequests ile ayni "sadece yaz, kimse okuyup/degistiremez"
    // deseni, sadece Firebase Console'dan incelenir). Basit bir sekil
    // dogrulamasi kotuye kullanimi azaltir.
    match /waitlist/{entryId} {
      allow create: if request.resource.data.email is string
        && request.resource.data.email.size() > 3
        && request.resource.data.email.size() < 200;
      allow read, update, delete: if false;
    }
  }
}
