rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Eski (gocten onceki) duz yol - artik sadece okuma icin, geriye
    // donuk uyumluluk (bu yolda hala eski yuklenmis fotograflar var).
    match /listings/{listingId}/{fileName} {
      allow read: if true;
    }
    // Sadece ilan sahibi fotograf yukleyip silebilir - listingId herkese
    // acik oldugu icin (ilan detayinda gorunur), bu kontrol olmadan
    // giris yapmis HERHANGI bir kullanici baskasinin ilan fotograflarini
    // silebilir/uzerine yazabilirdi. Sahiplik dogrudan yoldan (sellerId)
    // kontrol edilir - Firestore'a capraz sorgu (firestore.get) canli
    // ortamda guvenilmez ciktigi icin (yeni fotograf eklerken rastgele
    // "kaydedilemedi" hatasi) bu daha basit/saglam yonteme gecildi.
    match /listings/{listingId}/{sellerId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == sellerId;
    }
    match /avatars/{uid}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
