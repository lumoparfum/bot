rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /listings/{listingId}/{fileName} {
      allow read: if true;
      // Sadece ilan sahibi fotograf yukleyip silebilir - listingId herkese
      // acik oldugu icin (ilan detayinda gorunur), bu kontrol olmadan
      // giris yapmis HERHANGI bir kullanici baskasinin ilan fotograflarini
      // silebilir/uzerine yazabilirdi. Firestore'daki sellerId ile
      // caprazlanir (createListing/deleteListing bu yuzden once Firestore
      // belgesini olusturur/en son siler - siralamaya bagli).
      allow write: if request.auth != null
        && firestore.exists(/databases/(default)/documents/listings/$(listingId))
        && firestore.get(/databases/(default)/documents/listings/$(listingId)).data.sellerId == request.auth.uid;
    }
    match /avatars/{uid}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
